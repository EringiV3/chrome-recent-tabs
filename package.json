{
  "name": "recent-tabs-switcher",
  "version": "1.0.0",
  "description": "Switch between recently active tabs using an elegant overlay.",
  "main": "dist/background.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "package": "bash scripts/package.sh",
    "prepare-screenshots": "bash scripts/prepare-screenshots.sh"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^5.4.5"
  }
}
